# Streamlit Cloud secrets template.
# In Streamlit Cloud: App → Settings → Secrets → paste the filled-in version.
# Do NOT commit the real secrets.toml (it is gitignored).

APIFY_API_TOKEN = "apify_api_xxxxxxxxxxxxxxxxxxxxx"
DEFAULT_PROVIDER = "apify_gmaps"

# Optional — enable a password gate so only you can run searches (protects Apify credit):
# APP_PASSWORD = "choose-a-password"

# Optional — richer AI outreach copy via Claude:
# ANTHROPIC_API_KEY = "sk-ant-..."

# Optional — use Google Places instead of Apify:
# GOOGLE_PLACES_API_KEY = "AIzaSy..."
# DEFAULT_PROVIDER = "google_places"
