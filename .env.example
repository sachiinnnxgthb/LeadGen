# =============================================================================
# Lead Intelligence Platform — Environment Configuration
# Copy to `.env` and fill in. Every value has a sane default in settings.py;
# only API keys are strictly required for live data collection.
# Nested settings use a double-underscore delimiter, e.g. LEAD_SCORE__NO_WEBSITE.
# =============================================================================

# --- Application ----------------------------------------------------------
APP_ENV=development                # development | staging | production
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                     # true -> structured JSON logs (prod)
OUTPUT_DIR=./output                # where Excel/PDF/CSV/JSON exports are written

# --- Data providers -------------------------------------------------------
DEFAULT_PROVIDER=google_places     # google_places | apify_gmaps
GOOGLE_PLACES_API_KEY=
APIFY_API_TOKEN=
APIFY_ACTOR_ID=compass~crawler-google-places   # Google Maps scraper actor

# --- LLM provider (AI content generation) ---------------------------------
LLM_PROVIDER=anthropic             # anthropic | openai | none
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# --- Search defaults ------------------------------------------------------
SEARCH__CITY=Pune
SEARCH__STATE=Maharashtra
SEARCH__COUNTRY=India
SEARCH__MIN_RATING=0.0
SEARCH__MIN_REVIEWS=0
SEARCH__MAX_RESULTS_PER_CATEGORY=60

# --- Website audit thresholds --------------------------------------------
AUDIT__REQUEST_TIMEOUT_SECONDS=15
AUDIT__SLOW_RESPONSE_MS=3000       # response time above this is "slow"
AUDIT__MAX_RETRIES=2

# --- Lead score rules (0-10 scale, configurable weights) ------------------
LEAD_SCORE__NO_WEBSITE=4
LEAD_SCORE__BROKEN_WEBSITE=3
LEAD_SCORE__OUTDATED_WEBSITE=2
LEAD_SCORE__RATING_GT_THRESHOLD=2
LEAD_SCORE__REVIEWS_GT_THRESHOLD=2
LEAD_SCORE__HAS_INSTAGRAM=1
LEAD_SCORE__HAS_PHONE=1
LEAD_SCORE__RATING_THRESHOLD=4.5   # rating strictly above -> points
LEAD_SCORE__REVIEWS_THRESHOLD=100  # reviews strictly above -> points
LEAD_SCORE__HIGH_PRIORITY_MIN=7    # >= -> High
LEAD_SCORE__MEDIUM_PRIORITY_MIN=4  # >= -> Medium (else Low)

# --- Website score sub-weights (must sum to 1.0) --------------------------
WEBSITE_SCORE__PERFORMANCE=0.25
WEBSITE_SCORE__MOBILE=0.20
WEBSITE_SCORE__TRUST=0.20
WEBSITE_SCORE__SEO=0.15
WEBSITE_SCORE__USER_EXPERIENCE=0.20

# --- Package pricing (INR) ------------------------------------------------
PACKAGE__STARTER_PRICE=4999
PACKAGE__GROWTH_PRICE=8999
PACKAGE__PREMIUM_PRICE=14999

# --- Revenue projection (dashboard) ---------------------------------------
REVENUE__CONVERSION_RATE=0.05      # fraction of leads that convert
REVENUE__AVG_DEAL_VALUE=8999       # blended package value

# --- Agency identity (used in PDFs / outreach) ----------------------------
AGENCY__NAME=Your Agency Name
AGENCY__PHONE=+91-0000000000
AGENCY__EMAIL=hello@youragency.com
AGENCY__WEBSITE=https://youragency.com
